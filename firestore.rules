rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions for authentication and authorization
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(resource) {
      return request.auth.uid == resource.data.createdBy;
    }
    
    function isUser(userId) {
      return request.auth.uid == userId;
    }
    
    function hasValidUserData() {
      return request.resource.data.keys().hasAll(['name', 'email', 'createdAt']) &&
             request.resource.data.name is string &&
             request.resource.data.email is string &&
             request.resource.data.createdAt is timestamp;
    }
    
    function hasValidQuizData() {
      return request.resource.data.keys().hasAll(['title', 'description', 'createdBy', 'questions', 'isPublic', 'createdAt']) &&
             request.resource.data.title is string &&
             request.resource.data.description is string &&
             request.resource.data.createdBy is string &&
             request.resource.data.questions is list &&
             request.resource.data.isPublic is bool &&
             request.resource.data.createdAt is timestamp;
    }
    
    function hasValidGameSessionData() {
      return request.resource.data.keys().hasAll(['quizId', 'hostId', 'pin', 'status', 'players', 'currentQuestionIndex', 'createdAt']) &&
             request.resource.data.quizId is string &&
             request.resource.data.hostId is string &&
             request.resource.data.pin is string &&
             request.resource.data.status is string &&
             request.resource.data.players is map &&
             request.resource.data.currentQuestionIndex is number &&
             request.resource.data.createdAt is timestamp;
    }
    
    // Users collection rules
    match /users/{userId} {
      // Users can read and write their own data
      allow read, write: if isAuthenticated() && isUser(userId) && hasValidUserData();
      
      // Users can read other users' basic profile data (for leaderboards)
      allow read: if isAuthenticated() && 
                     resource.data.keys().hasAll(['name', 'email', 'createdAt']);
    }
    
    // Quizzes collection rules  
    match /quizzes/{quizId} {
      // Anyone can read public quizzes
      allow read: if resource.data.isPublic == true;
      
      // Authenticated users can read private quizzes they created
      allow read: if isAuthenticated() && isOwner(resource);
      
      // Authenticated users can create quizzes
      allow create: if isAuthenticated() && 
                       hasValidQuizData() &&
                       request.auth.uid == request.resource.data.createdBy;
      
      // Quiz creators can update and delete their quizzes
      allow update, delete: if isAuthenticated() && isOwner(resource);
    }
    
    // Game sessions collection rules
    match /game_sessions/{sessionId} {
      // Game hosts can create game sessions
      allow create: if isAuthenticated() && 
                       hasValidGameSessionData() &&
                       request.auth.uid == request.resource.data.hostId;
      
      // Game hosts can update their game sessions
      allow update: if isAuthenticated() && 
                       request.auth.uid == resource.data.hostId;
      
      // Players can read game sessions they're part of
      allow read: if isAuthenticated() && 
                     (request.auth.uid == resource.data.hostId ||
                      request.auth.uid in resource.data.players.keys());
      
      // Game hosts can delete their game sessions
      allow delete: if isAuthenticated() && 
                       request.auth.uid == resource.data.hostId;
      
      // Players can join game sessions (add themselves to players map)
      allow update: if isAuthenticated() &&
                       resource.data.status == 'waiting' &&
                       request.resource.data.players.size() <= 50 && // Max 50 players
                       request.auth.uid in request.resource.data.players.keys() &&
                       !(request.auth.uid in resource.data.players.keys()); // Not already joined
    }
    
    // Leaderboards collection rules
    match /leaderboards/{sessionId} {
      // Anyone in the game session can read the leaderboard
      allow read: if isAuthenticated();
      
      // Only game hosts can create/update leaderboards
      allow create, update: if isAuthenticated() &&  
                               exists(/databases/$(database)/documents/game_sessions/$(sessionId)) &&
                               get(/databases/$(database)/documents/game_sessions/$(sessionId)).data.hostId == request.auth.uid;
      
      // Game hosts can delete leaderboards
      allow delete: if isAuthenticated() &&
                       exists(/databases/$(database)/documents/game_sessions/$(sessionId)) &&
                       get(/databases/$(database)/documents/game_sessions/$(sessionId)).data.hostId == request.auth.uid;
    }
    
    // Connectivity test collection (for network checks)
    match /_connection_test/{document=**} {
      allow read: if isAuthenticated();
    }
    
    // Firestore connectivity check collection
    match /_firestore_connectivity_check/{document=**} {
      allow read: if isAuthenticated();
    }
    
    // Default deny rule for all other documents
    match /{document=**} {
      allow read, write: if false;
    }
  }
}