rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================
    // SECURITY HELPER FUNCTIONS
    // ============================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(resource) {
      return request.auth.uid == resource.data.createdBy;
    }
    
    function isUser(userId) {
      return request.auth.uid == userId;
    }
    
    // ============================
    // COMPREHENSIVE DATA VALIDATION FUNCTIONS
    // ============================
    
    // Validate user data with comprehensive field checks
    function validateUserData(data) {
      return data.keys().hasAll(['name', 'email', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.matches('.*@.*\\..*') && data.email.size() <= 254 &&
             data.createdAt is timestamp &&
             (!('stats' in data) || (data.stats is map && validateUserStats(data.stats)));
    }
    
    // Validate user stats object
    function validateUserStats(stats) {
      return (!('totalQuizzes' in stats) || stats.totalQuizzes is number) &&
             (!('totalGamesPlayed' in stats) || stats.totalGamesPlayed is number) &&
             (!('totalGamesWon' in stats) || stats.totalGamesWon is number) &&
             (!('averageScore' in stats) || stats.averageScore is number);
    }
    
    // Validate quiz data with comprehensive validation
    function validateQuizData(data) {
      return data.keys().hasAll(['title', 'description', 'createdBy', 'questions', 'isPublic', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 1000 &&
             data.createdBy is string &&
             data.questions is list && data.questions.size() > 0 && data.questions.size() <= 50 &&
             data.isPublic is bool &&
             data.createdAt is timestamp &&
             validateQuestions(data.questions) &&
             (!('category' in data) || (data.category is string && data.category.size() <= 50)) &&
             (!('estimatedDuration' in data) || (data.estimatedDuration is number && data.estimatedDuration > 0)) &&
             (!('isDraft' in data) || data.isDraft is bool) &&
             (!('lastModified' in data) || data.lastModified is timestamp);
    }
    
    // Validate questions array with detailed validation
    function validateQuestions(questions) {
      return questions.size() > 0 && questions.size() <= 50 && 
             validateQuestion(questions[0]);
    }
    
    // Validate individual question structure
    function validateQuestion(question) {
      return question.keys().hasAll(['question', 'options', 'correctAnswer', 'timeLimit']) &&
             question.question is string && question.question.size() > 0 && question.question.size() <= 500 &&
             question.options is list && question.options.size() >= 2 && question.options.size() <= 6 &&
             question.correctAnswer is number && question.correctAnswer >= 0 && question.correctAnswer < question.options.size() &&
             question.timeLimit is number && question.timeLimit > 0 && question.timeLimit <= 300 &&
             validateQuestionOptions(question.options) &&
             (!('points' in question) || (question.points is number && question.points > 0 && question.points <= 1000)) &&
             (!('imageUrl' in question) || (question.imageUrl is string && question.imageUrl.size() <= 2000));
    }
    
    // Validate question options
    function validateQuestionOptions(options) {
      return options[0] is string && options[0].size() > 0 && options[0].size() <= 200;
    }
    
    // Validate game session data with enhanced validation
    function validateGameSessionData(data) {
      return data.keys().hasAll(['quizId', 'hostId', 'pin', 'status', 'players', 'currentQuestionIndex', 'createdAt']) &&
             data.quizId is string &&
             data.hostId is string &&
             data.pin is string && data.pin.size() == 6 && data.pin.matches('[0-9]{6}') &&
             data.status in ['waiting', 'active', 'completed'] &&
             data.players is map && data.players.size() <= 50 &&
             data.currentQuestionIndex is number && data.currentQuestionIndex >= 0 &&
             data.createdAt is timestamp &&
             (!('settings' in data) || validateGameSettings(data.settings)) &&
             (!('startedAt' in data) || data.startedAt is timestamp) &&
             (!('completedAt' in data) || data.completedAt is timestamp);
    }
    
    // Validate game session settings
    function validateGameSettings(settings) {
      return (!('maxPlayers' in settings) || (settings.maxPlayers is number && settings.maxPlayers > 0 && settings.maxPlayers <= 50)) &&
             (!('showCorrectAnswers' in settings) || settings.showCorrectAnswers is bool) &&
             (!('shuffleQuestions' in settings) || settings.shuffleQuestions is bool) &&
             (!('allowReplay' in settings) || settings.allowReplay is bool);
    }
    
    // Validate player data when joining
    function validatePlayerJoin(playerId, playerData) {
      return playerData.keys().hasAll(['name', 'joinedAt']) &&
             playerData.name is string && playerData.name.size() > 0 && playerData.name.size() <= 100 &&
             playerData.joinedAt is timestamp &&
             (!('score' in playerData) || playerData.score is number) &&
             (!('answers' in playerData) || playerData.answers is list) &&
             (!('isReady' in playerData) || playerData.isReady is bool);
    }
    
    // Validate leaderboard data
    function validateLeaderboardData(data) {
      return data.keys().hasAll(['scores', 'updatedAt']) &&
             data.scores is list && data.scores.size() <= 50 &&
             data.updatedAt is timestamp &&
             (data.scores.size() == 0 || validateScore(data.scores[0])) &&
             (!('finalResults' in data) || data.finalResults is bool);
    }
    
    // Validate individual score entry
    function validateScore(score) {
      return score.keys().hasAll(['playerId', 'playerName', 'score', 'correctAnswers', 'totalAnswers']) &&
             score.playerId is string &&
             score.playerName is string && score.playerName.size() > 0 && score.playerName.size() <= 100 &&
             score.score is number && score.score >= 0 &&
             score.correctAnswers is number && score.correctAnswers >= 0 &&
             score.totalAnswers is number && score.totalAnswers >= 0 &&
             score.correctAnswers <= score.totalAnswers &&
             (!('rank' in score) || score.rank is number) &&
             (!('timeTaken' in score) || score.timeTaken is number);
    }
    
    // ============================
    // SECURITY DATA VALIDATION FUNCTIONS
    // ============================
    
    // Validate user session data
    function validateSessionData(data) {
      return data.keys().hasAll(['sessionId', 'userId', 'createdAt', 'lastActiveAt', 'deviceId', 'deviceName', 'deviceType', 'ipAddress', 'userAgent', 'isActive']) &&
             data.sessionId is string && data.sessionId.size() > 0 &&
             data.userId is string && data.userId.size() > 0 &&
             data.createdAt is timestamp &&
             data.lastActiveAt is timestamp &&
             data.deviceId is string && data.deviceId.size() > 0 &&
             data.deviceName is string && data.deviceName.size() > 0 && data.deviceName.size() <= 200 &&
             data.deviceType in ['mobile', 'tablet', 'desktop', 'unknown'] &&
             data.ipAddress is string && data.ipAddress.size() > 0 && data.ipAddress.size() <= 45 &&
             data.userAgent is string && data.userAgent.size() <= 500 &&
             data.isActive is bool &&
             (!('trustLevel' in data) || data.trustLevel in ['unknown', 'trusted', 'suspicious', 'revoked']) &&
             (!('expiresAt' in data) || data.expiresAt is timestamp) &&
             (!('metadata' in data) || data.metadata is map);
    }
    
    // Validate user device data
    function validateDeviceData(data) {
      return data.keys().hasAll(['deviceId', 'userId', 'deviceName', 'deviceType', 'platform', 'firstSeenAt', 'lastSeenAt']) &&
             data.deviceId is string && data.deviceId.size() > 0 &&
             data.userId is string && data.userId.size() > 0 &&
             data.deviceName is string && data.deviceName.size() > 0 && data.deviceName.size() <= 200 &&
             data.deviceType in ['mobile', 'tablet', 'desktop', 'unknown'] &&
             data.platform in ['android', 'ios', 'web', 'windows', 'macos', 'linux', 'unknown'] &&
             data.firstSeenAt is timestamp &&
             data.lastSeenAt is timestamp &&
             (!('trustLevel' in data) || data.trustLevel in ['unknown', 'trusted', 'suspicious', 'revoked']) &&
             (!('isRevoked' in data) || data.isRevoked is bool) &&
             (!('fcmToken' in data) || (data.fcmToken is string && data.fcmToken.size() <= 500)) &&
             (!('deviceFingerprint' in data) || data.deviceFingerprint is map) &&
             (!('sessionIds' in data) || (data.sessionIds is list && data.sessionIds.size() <= 50));
    }
    
    // Validate security event data
    function validateSecurityEventData(data) {
      return data.keys().hasAll(['eventId', 'userId', 'eventType', 'timestamp', 'severity', 'description']) &&
             data.eventId is string && data.eventId.size() > 0 &&
             data.userId is string && data.userId.size() > 0 &&
             data.eventType in ['login_success', 'login_failed', 'password_change', 'session_terminated', 'suspicious_activity', 'new_device', 'device_revoked'] &&
             data.timestamp is timestamp &&
             data.severity in ['low', 'medium', 'high', 'critical'] &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 1000 &&
             (!('deviceId' in data) || (data.deviceId is string && data.deviceId.size() > 0)) &&
             (!('ipAddress' in data) || (data.ipAddress is string && data.ipAddress.size() <= 45)) &&
             (!('userAgent' in data) || (data.userAgent is string && data.userAgent.size() <= 500)) &&
             (!('metadata' in data) || data.metadata is map);
    }
    
    // Validate security settings data
    function validateSecuritySettingsData(data) {
      return data.keys().hasAll(['userId']) &&
             data.userId is string && data.userId.size() > 0 &&
             (!('twoFactorEnabled' in data) || data.twoFactorEnabled is bool) &&
             (!('sessionTimeoutEnabled' in data) || data.sessionTimeoutEnabled is bool) &&
             (!('sessionTimeoutMinutes' in data) || (data.sessionTimeoutMinutes is number && data.sessionTimeoutMinutes >= 5 && data.sessionTimeoutMinutes <= 1440)) &&
             (!('maxActiveSessions' in data) || (data.maxActiveSessions is number && data.maxActiveSessions >= 1 && data.maxActiveSessions <= 20)) &&
             (!('suspiciousActivityAlerts' in data) || data.suspiciousActivityAlerts is bool) &&
             (!('newDeviceAlerts' in data) || data.newDeviceAlerts is bool) &&
             (!('trustedDevices' in data) || (data.trustedDevices is list && data.trustedDevices.size() <= 50)) &&
             (!('lastUpdated' in data) || data.lastUpdated is timestamp);
    }
    
    // ============================
    // USERS COLLECTION RULES
    // ============================
    match /users/{userId} {
      // Users can read and write their own data with validation
      allow read: if isAuthenticated() && isUser(userId);
      
      allow create: if isAuthenticated() && 
                       isUser(userId) &&
                       validateUserData(request.resource.data);
      
      allow update: if isAuthenticated() && 
                       isUser(userId) &&
                       validateUserData(request.resource.data) &&
                       !('createdAt' in request.resource.data.diff(resource.data).affectedKeys());
      
      // Users can read other users' basic profile data (for leaderboards)
      allow read: if isAuthenticated() && 
                     resource.data.keys().hasAll(['name', 'email', 'createdAt']);
      
      // ============================
      // USER SESSIONS SUBCOLLECTION
      // ============================
      match /sessions/{sessionId} {
        // Users can only access their own sessions
        allow read, write: if isAuthenticated() && isUser(userId);
        
        // Validate session data structure
        allow create, update: if isAuthenticated() && 
                                 isUser(userId) &&
                                 validateSessionData(request.resource.data);
      }
      
      // ============================
      // USER DEVICES SUBCOLLECTION
      // ============================
      match /devices/{deviceId} {
        // Users can only access their own devices
        allow read, write: if isAuthenticated() && isUser(userId);
        
        // Validate device data structure
        allow create, update: if isAuthenticated() && 
                                 isUser(userId) &&
                                 validateDeviceData(request.resource.data);
      }
      
      // ============================
      // SECURITY EVENTS SUBCOLLECTION
      // ============================
      match /security_events/{eventId} {
        // Users can read their own security events but only append new ones
        allow read: if isAuthenticated() && isUser(userId);
        
        // Security events are append-only (no updates allowed)
        allow create: if isAuthenticated() && 
                         isUser(userId) &&
                         validateSecurityEventData(request.resource.data);
        
        // No updates or deletes allowed for security events (audit trail)
        allow update, delete: if false;
      }
      
      // ============================
      // USER SETTINGS SUBCOLLECTION
      // ============================
      match /settings/{settingType} {
        // Users can read and write their own settings
        allow read, write: if isAuthenticated() && isUser(userId);
        
        // Validate security settings when updating security document
        allow create, update: if isAuthenticated() && 
                                 isUser(userId) &&
                                 (settingType != 'security' || validateSecuritySettingsData(request.resource.data));
      }
    }
    
    // ============================
    // QUIZZES COLLECTION RULES  
    // ============================
    match /quizzes/{quizId} {
      // Anyone can read public quizzes
      allow read: if isAuthenticated() && resource.data.isPublic == true;
      
      // Quiz creators can read their own quizzes (public or private)
      allow read: if isAuthenticated() && isOwner(resource);
      
      // Authenticated users can create quizzes with validation
      allow create: if isAuthenticated() && 
                       validateQuizData(request.resource.data) &&
                       request.auth.uid == request.resource.data.createdBy;
      
      // Quiz creators can update their quizzes (but not change ownership or creation date)
      allow update: if isAuthenticated() && 
                       isOwner(resource) &&
                       validateQuizData(request.resource.data) &&
                       !('createdBy' in request.resource.data.diff(resource.data).affectedKeys()) &&
                       !('createdAt' in request.resource.data.diff(resource.data).affectedKeys());
      
      // Quiz creators can delete their quizzes
      allow delete: if isAuthenticated() && isOwner(resource);
      
      // ============================
      // ACTIVE EDITORS SUBCOLLECTION
      // ============================
      match /active_editors/{editorId} {
        // Quiz owner and active editors can read the list
        allow read: if isAuthenticated() && 
                       (isOwner(get(/databases/$(database)/documents/quizzes/$(quizId))) || 
                        request.auth.uid == editorId);
        
        // Users can register themselves as editors
        allow create: if isAuthenticated() && 
                         request.auth.uid == editorId &&
                         request.resource.data.keys().hasAll(['userId', 'userName', 'joinedAt', 'lastActiveAt']) &&
                         request.resource.data.userId == request.auth.uid;
        
        // Users can update their own editor status
        allow update: if isAuthenticated() && 
                         request.auth.uid == editorId &&
                         request.resource.data.userId == resource.data.userId;
        
        // Users can remove themselves or quiz owner can remove anyone
        allow delete: if isAuthenticated() && 
                         (request.auth.uid == editorId || 
                          isOwner(get(/databases/$(database)/documents/quizzes/$(quizId))));
      }
    }
    
    // ============================
    // GAME SESSIONS COLLECTION RULES
    // ============================
    match /game_sessions/{sessionId} {
      // Host can read/write their game sessions
      allow read, write: if isAuthenticated() && 
                            request.auth.uid == resource.data.hostId;
      
      // Players can read active game sessions they're part of
      allow read: if isAuthenticated() && 
                     (resource.data.status == 'active' || resource.data.status == 'waiting') &&
                     request.auth.uid in resource.data.players.keys());
      
      // Create new game session with validation
      allow create: if isAuthenticated() &&
                       validateGameSessionData(request.resource.data) &&
                       request.auth.uid == request.resource.data.hostId;
      
      // Host can update game session (except immutable fields)
      allow update: if isAuthenticated() && 
                       request.auth.uid == resource.data.hostId &&
                       validateGameSessionData(request.resource.data) &&
                       !('createdAt' in request.resource.data.diff(resource.data).affectedKeys()) &&
                       !('hostId' in request.resource.data.diff(resource.data).affectedKeys());
      
      // Players can join game sessions (add themselves to players map)
      allow update: if isAuthenticated() &&
                       resource.data.status == 'waiting' &&
                       request.resource.data.players.size() <= 50 &&
                       request.auth.uid in request.resource.data.players.keys() &&
                       !(request.auth.uid in resource.data.players.keys()) &&
                       validatePlayerJoin(request.auth.uid, request.resource.data.players[request.auth.uid]) &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['players']);
      
      // Host can delete their game sessions
      allow delete: if isAuthenticated() && 
                       request.auth.uid == resource.data.hostId;
    }
    
    // ============================
    // LEADERBOARDS COLLECTION RULES
    // ============================
    match /leaderboards/{sessionId} {
      // Anyone who can read the game session can read its leaderboard
      allow read: if isAuthenticated() && 
        (
          // Host can always read
          exists(/databases/$(database)/documents/game_sessions/$(sessionId)) &&
          get(/databases/$(database)/documents/game_sessions/$(sessionId)).data.hostId == request.auth.uid
        ) ||
        (
          // Players in active/completed session can read
          exists(/databases/$(database)/documents/game_sessions/$(sessionId)) &&
          request.auth.uid in get(/databases/$(database)/documents/game_sessions/$(sessionId)).data.players.keys() &&
          get(/databases/$(database)/documents/game_sessions/$(sessionId)).data.status in ['active', 'completed']
        );
      
      // Only host can create/update leaderboard with validation
      allow create, update: if isAuthenticated() &&  
                               exists(/databases/$(database)/documents/game_sessions/$(sessionId)) &&
                               get(/databases/$(database)/documents/game_sessions/$(sessionId)).data.hostId == request.auth.uid &&
                               validateLeaderboardData(request.resource.data);
      
      // Host can delete leaderboards
      allow delete: if isAuthenticated() &&
                       exists(/databases/$(database)/documents/game_sessions/$(sessionId)) &&
                       get(/databases/$(database)/documents/game_sessions/$(sessionId)).data.hostId == request.auth.uid;
    }
    
    // ============================
    // UTILITY COLLECTIONS
    // ============================
    
    // Connectivity test collection (for network checks)
    match /_connection_test/{document=**} {
      allow read: if isAuthenticated();
    }
    
    // Firestore connectivity check collection
    match /_firestore_connectivity_check/{document=**} {
      allow read: if isAuthenticated();
    }
    
    // System health check collection (for monitoring)
    match /_system_health/{document=**} {
      allow read: if isAuthenticated();
    }
    
    // Development seeding collection (for test data)
    match /_dev_seed/{document=**} {
      allow read, write: if isAuthenticated() && 
                            request.auth.token.email.matches('.*@.*\\..*');
    }
    
    // ============================
    // DEFAULT SECURITY RULES
    // ============================
    
    // Default deny rule for all other documents
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// ===========================
// FIREBASE STORAGE RULES
// ===========================

service firebase.storage {
  match /b/{bucket}/o {
    
    // ============================
    // HELPER FUNCTIONS FOR STORAGE
    // ============================
    
    /// Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    /// Check if user is the owner of the file
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    /// Validate image file type
    function isValidImageType() {
      return request.resource.contentType.matches('image/(jpeg|png|webp)');
    }
    
    /// Validate file extension
    function isValidImageExtension(extension) {
      return extension.matches('(jpg|jpeg|png|webp)');
    }
    
    /// Check file size is within limits (5MB for free tier)
    function isValidFileSize() {
      return request.resource.size <= 5 * 1024 * 1024; // 5MB
    }
    
    // ============================
    // USER AVATAR STORAGE RULES
    // ============================
    
    match /users/{userId}/avatar.{extension} {
      // Allow read for authenticated users (avatars can be viewed by others)
      allow read: if isAuthenticated();
      
      // Allow write only for the owner of the avatar with validation
      allow write: if isOwner(userId) &&
                      isValidFileSize() &&
                      isValidImageExtension(extension) &&
                      isValidImageType();
      
      // Allow delete only for the owner
      allow delete: if isOwner(userId);
    }
    
    // Alternative path structure for avatars (in case multiple formats exist)
    match /users/{userId}/{fileName} {
      // Allow read for authenticated users
      allow read: if isAuthenticated() && fileName.matches('avatar\\.(jpg|jpeg|png|webp)');
      
      // Allow write for owner with validation
      allow write: if isOwner(userId) &&
                      fileName.matches('avatar\\.(jpg|jpeg|png|webp)') &&
                      isValidFileSize() &&
                      isValidImageType();
      
      // Allow delete for owner
      allow delete: if isOwner(userId) && fileName.matches('avatar\\.(jpg|jpeg|png|webp)');
    }
    
    // ============================
    // QUIZ IMAGES STORAGE RULES
    // ============================
    
    match /quizzes/{quizId}/{imageId} {
      // Allow read for authenticated users (quiz images can be viewed by participants)
      allow read: if isAuthenticated();
      
      // Allow write for authenticated users (ownership validated by Firestore rules)
      // Additional validation for image files
      allow write: if isAuthenticated() &&
                      isValidFileSize() &&
                      isValidImageType();
      
      // Allow delete for authenticated users (ownership validated by Firestore rules)
      allow delete: if isAuthenticated();
    }
    
    // ============================
    // GAME SESSION ATTACHMENTS RULES
    // ============================
    
    match /game_sessions/{sessionId}/{attachmentId} {
      // Allow read for authenticated users
      allow read: if isAuthenticated();
      
      // Allow write for authenticated users with file validation
      allow write: if isAuthenticated() &&
                      isValidFileSize() &&
                      (isValidImageType() || 
                       request.resource.contentType.matches('application/(pdf|json)') ||
                       request.resource.contentType.matches('text/plain'));
      
      // Allow delete for authenticated users
      allow delete: if isAuthenticated();
    }
    
    // ============================
    // TEMP UPLOADS (FOR PROCESSING)
    // ============================
    
    match /temp/{userId}/{fileName} {
      // Temporary storage for image processing
      // Allow read/write for owner with time-based cleanup (files should be moved/deleted quickly)
      allow read, write: if isOwner(userId) &&
                            isValidFileSize() &&
                            isValidImageType();
      
      allow delete: if isOwner(userId);
    }
    
    // ============================
    // DEFAULT STORAGE SECURITY
    // ============================
    
    // Deny all other storage access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}